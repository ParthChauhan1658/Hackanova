# ── Redis ──────────────────────────────────────────────────────────────────────
REDIS_URL=

# ── PostgreSQL (SQLAlchemy async URL — must use postgresql+asyncpg://) ─────────
DATABASE_URL=

# ── Isolation Forest model path ───────────────────────────────────────────────
# Path resolved automatically from main.py — leave blank to use default
# IF_MODEL_PATH=

# ── Anthropic (Claude) ────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ── Google (Gemini) ───────────────────────────────────────────────────────────
GEMINI_API_KEY=

# ── Twilio (SMS + voice fallback) ─────────────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# ── Emergency contacts (comma-separated) ──────────────────────────────────────
EMERGENCY_CONTACT_NUMBERS=
EMERGENCY_CONTACT_EMAILS=

# ── Resend (email alerts — replaces SendGrid, no sender verification needed) ──
RESEND_API_KEY=
# From address: use onboarding@resend.dev (works immediately) OR your verified domain
RESEND_FROM_EMAIL=

# ── Firebase FCM (push notifications) ────────────────────────────────────────
# Paste the full service-account JSON as a single-line string
# FIREBASE_CREDENTIALS_JSON={"type":"service_account","project_id":"..."}

# ── EMS dispatch API ──────────────────────────────────────────────────────────
# Leave unset (or set to the mock URL) during development — mock dispatch is used
EMS_API_URL=

# ── Simulator CSV data directory ───────────────────────────────────────────────
CSV_DATA_DIR=

# ── Auto-simulation (backend auto-starts on uvicorn startup) ──────────────────
# Interval between CSV rows in seconds. Lower = faster simulation.
# 0.5 = one reading every 500 ms  |  2.0 = one reading every 2 s
SIMULATE_INTERVAL=

# ── Calendly (appointment booking) ────────────────────────────────────────────
# Get your Personal Access Token from:
# https://calendly.com/integrations/api_webhooks → Personal Access Tokens
CALENDLY_API_TOKEN=

# ── SerpAPI (Google Maps doctor ratings enrichment) ───────────────────────────
# Get your key from https://serpapi.com/manage-api-key
# Leave blank to skip rating enrichment (OSM-only mode)
SERP_API_KEY=bd96c7fd9451acf9da7d48fd8f7d2700e555afe6c8064c7d0e9caeb647e504bb
